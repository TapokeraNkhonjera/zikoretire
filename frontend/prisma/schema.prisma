generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model Notification {
  id String @id @default(cuid())
  userId String
  simulationId String? // Optional link to specific simulation
  
  title String
  message String
  type String // info, success, warning, error, admin
  priority String @default("medium") // low, medium, high
  
  read Boolean @default(false)
  
  // Optional link to related resource
  linkUrl String?
  linkText String?
  
  // For admin notifications
  isGlobal Boolean @default(false)
  targetRole String? // USER, ADMIN, null for all
  
  createdAt DateTime @default(now())
  readAt DateTime?
  
  user User @relation(fields: [userId], references: [id])
  simulation Simulation? @relation(fields: [simulationId], references: [id])
}

enum ScenarioType {
  CONSERVATIVE
  BALANCED
  AGGRESSIVE
  INFORMAL
  SEASONAL
  INFLATION_STRESS
  CONTRIBUTION_GROWTH
  EARLY_RETIREMENT
  SUSTAINABILITY
  CUSTOM
}

enum GrowthModel {
  STABLE
  BALANCED
  HIGH
}

enum IncomeType {
  STABLE
  FLEXIBLE
  SEASONAL
}

enum SavingBehavior {
  CONSISTENT
  FLEXIBLE
  OPPORTUNISTIC
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String

  role Role @default(USER)

  emailVerified DateTime?
  image         String?
  mlTrainingConsent Boolean @default(false)

  simulations Simulation[]
  scenarios   Scenario[]
  notifications Notification[]
  mlLearningData MLLearningData[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Simulation {
  id     String @id @default(cuid())
  userId String
  name   String // User-defined name for better organization and searching

  /**
   * ================= CORE AGE DATA =================
   */

  age           Int
  retirementAge Int

  /**
   * ================= FINANCIAL =================
   */

  monthlyIncome       Float
  monthlyContribution Float
  currentSavings      Float?

  inflationRate Float

  /**
   * ================= NEW INPUTS (FROM FORM) =================
   */

  growthModel    GrowthModel
  incomeType     IncomeType
  savingBehavior SavingBehavior

  includeIrregular  Boolean @default(false)
  extraContribution Float?

  lifestyle String

  historicalData Json?

  /**
   * ================= PRIORITY =================
   */

  priority Boolean @default(false) // true = main simulation, false = test/analytical

  /**
   * ================= RELATIONS =================
   */

  user User @relation(fields: [userId], references: [id])

  result          Result?
  recommendations Recommendation[]
  scenarios       Scenario[]
  notifications   Notification[]

  createdAt DateTime @default(now())
}

model Result {
  id           String @id @default(cuid())
  simulationId String @unique

  /**
   * ================= CORE OUTPUT =================
   */

  projectedSavings       Float
  estimatedMonthlyIncome Float

  inflationAdjustedValue Float

  rsiScore Float

  readinessLevel String

  /**
   * ================= ML OUTPUTS =================
   */
  readinessScore        Float?
  consistencyScore     Float?
  volatilityScore      Float?
  sustainabilityScore  Float?
  inflationVulnerability Float?
  riskScore           Float?
  confidenceScore       Float?

  simulation Simulation @relation(fields: [simulationId], references: [id])

  createdAt DateTime @default(now())
}

model Scenario {
  id String @id @default(cuid())

  userId       String
  simulationId String

  name         String // User-defined name for better identification
  scenarioType ScenarioType?

  /**
   * ================= OVERRIDES =================
   */

  age           Int?
  retirementAge Int?

  monthlyIncome       Float?
  monthlyContribution Float?

  currentSavings Float?
  inflationRate  Float?

  growthModel    GrowthModel?
  incomeType     IncomeType?
  savingBehavior SavingBehavior?

  includeIrregular  Boolean?
  extraContribution Float?

  lifestyle String?

  historicalData Json?

  /**
   * ================= RELATIONS =================
   */

  user       User       @relation(fields: [userId], references: [id])
  simulation Simulation @relation(fields: [simulationId], references: [id])

  result          ScenarioResult?
  recommendations Recommendation[]

  createdAt DateTime @default(now())
}

model ScenarioResult {
  id         String @id @default(cuid())
  scenarioId String @unique

  projectedSavings       Float
  estimatedMonthlyIncome Float
  inflationAdjustedValue Float
  rsiScore Float
  readinessLevel String

  /**
   * ================= ML OUTPUTS =================
   */
  readinessScore        Float?
  consistencyScore     Float?
  volatilityScore      Float?
  sustainabilityScore  Float?
  inflationVulnerability Float?
  riskScore           Float?
  confidenceScore       Float?

  scenario Scenario @relation(fields: [scenarioId], references: [id])
  createdAt DateTime @default(now())
}

model Recommendation {
  id String @id @default(cuid())

  simulationId String?
  scenarioId   String?
  message String
  type    String
  confidenceScore Float?

  /**
   * ================= ML EXPLAINABILITY =================
   */
  featureImpacts Json?
  explanation String?
  engineType String?

  simulation Simulation? @relation(fields: [simulationId], references: [id])
  scenario   Scenario?   @relation(fields: [scenarioId], references: [id])

  createdAt DateTime @default(now())
}

model StrategyComparison {
  id         String @id @default(cuid())
  userId       String
  
  /**
   * ================= INPUTS =================
   */
  baseSimulationId String
  strategiesCompared Json
  bestStrategy String
  worstStrategy String
  
  /**
   * ================= COMPARISON RESULTS =================
   */
  averageRsiScore Float
  bestRsiScore Float
  worstRsiScore Float
  spreadRsiScore Float
  
  averageProjectedSavings Float
  bestProjectedSavings Float
  worstProjectedSavings Float
  spreadProjectedSavings Float
  
  createdAt DateTime @default(now())
}

model MLModelVersion {
  id         String @id @default(cuid())
  version     String @unique
  modelType   String
  status      String
  accuracyR2  Float?
  accuracyMse Float?
}

model PasswordResetToken {
id String @id @default(cuid())

email String
token     String   @unique
expiresAt DateTime

createdAt DateTime @default(now())
}

model MLLearningData {
  id String @id @default(cuid())
  userId String
  
  type String // 'comparison', 'scenario_analysis', 'feedback', 'interaction'
  data Json // Comparison data, scenario data, etc.
  userInteractions Json? // Click patterns, time spent, etc.
  context Json? // User context, session info, etc.
  
  user User @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

enum ScenarioType {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  CUSTOM
}

enum GrowthModel {
  STABLE
  BALANCED
  HIGH
}

enum IncomeType {
  STABLE
  FLEXIBLE
  SEASONAL
}

enum SavingBehavior {
  CONSISTENT
  FLEXIBLE
  OPPORTUNISTIC
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String

  role Role @default(USER)

  emailVerified DateTime?
  image         String?

  simulations Simulation[]
  scenarios   Scenario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Simulation {
  id     String @id @default(cuid())
  userId String

  /**
   * ================= CORE AGE DATA =================
   */

  age           Int
  retirementAge Int

  /**
   * ================= FINANCIAL =================
   */

  monthlyIncome       Float
  monthlyContribution Float
  currentSavings      Float?

  inflationRate Float

  /**
   * ================= NEW INPUTS (FROM FORM) =================
   */

  growthModel    GrowthModel
  incomeType     IncomeType
  savingBehavior SavingBehavior

  includeIrregular  Boolean @default(false)
  extraContribution Float?

  lifestyle String

  /**
   * ================= RELATIONS =================
   */

  user User @relation(fields: [userId], references: [id])

  result          Result?
  recommendations Recommendation[]
  scenarios       Scenario[]

  createdAt DateTime @default(now())
}

model Result {
  id           String @id @default(cuid())
  simulationId String @unique

  /**
   * ================= CORE OUTPUT =================
   */

  projectedSavings       Float
  estimatedMonthlyIncome Float

  inflationAdjustedValue Float

  rsiScore Float

  readinessLevel String

  /**
   * ================= OPTIONAL ML OUTPUT =================
   */

  riskScore       Float?
  confidenceScore Float?

  simulation Simulation @relation(fields: [simulationId], references: [id])

  createdAt DateTime @default(now())
}

model Scenario {
  id String @id @default(cuid())

  userId       String
  simulationId String

  name         String
  scenarioType ScenarioType?

  /**
   * ================= OVERRIDES =================
   */

  age           Int?
  retirementAge Int?

  monthlyIncome       Float?
  monthlyContribution Float?

  currentSavings Float?
  inflationRate  Float?

  growthModel    GrowthModel?
  incomeType     IncomeType?
  savingBehavior SavingBehavior?

  includeIrregular  Boolean?
  extraContribution Float?

  lifestyle String?

  /**
   * ================= RELATIONS =================
   */

  user       User       @relation(fields: [userId], references: [id])
  simulation Simulation @relation(fields: [simulationId], references: [id])

  result          ScenarioResult?
  recommendations Recommendation[]

  createdAt DateTime @default(now())
}

model ScenarioResult {
  id         String @id @default(cuid())
  scenarioId String @unique

  projectedSavings       Float
  estimatedMonthlyIncome Float

  inflationAdjustedValue Float

  rsiScore Float

  readinessLevel String

  riskScore       Float?
  confidenceScore Float?

  scenario Scenario @relation(fields: [scenarioId], references: [id])

  createdAt DateTime @default(now())
}

model Recommendation {
  id String @id @default(cuid())

  simulationId String?
  scenarioId   String?

  message String
  type    String

  confidenceScore Float?

  simulation Simulation? @relation(fields: [simulationId], references: [id])
  scenario   Scenario?   @relation(fields: [scenarioId], references: [id])

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id String @id @default(cuid())

  email String

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
}

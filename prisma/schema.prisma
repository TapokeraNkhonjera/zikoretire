generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String   // ✅ NOT nullable now

  role      Role     @default(USER)


  emailVerified DateTime?
  image         String?


  simulations Simulation[]
  scenarios   Scenario[]


  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Simulation {
  id                   String   @id @default(cuid())
  userId               String
  age                  Int
  retirementAge        Int
  monthlyIncome        Float
  monthlyContribution  Float
  currentSavings       Float?
  inflationRate        Float
  lifestyle            String

  user   User   @relation(fields: [userId], references: [id])
  result Result?
  recommendations Recommendation[]

  createdAt DateTime @default(now())
}

model Result {
  id                         String  @id @default(cuid())
  simulationId               String  @unique
  projectedValue             Float
  monthlyRetirementIncome    Float
  rsiScore                   Float
  readinessLevel             String

  simulation Simulation @relation(fields: [simulationId], references: [id])

  createdAt DateTime @default(now())
}

model Scenario {
  id                    String  @id @default(cuid())
  userId                String
  name                  String
  baseSimulationId      String
  modifiedContribution  Float?
  modifiedRetirementAge Int?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Recommendation {
  id              String  @id @default(cuid())
  simulationId    String
  message         String
  type            String
  confidenceScore Float?

  simulation Simulation @relation(fields: [simulationId], references: [id])

  createdAt DateTime @default(now())
}